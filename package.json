{
  "name": "vflow-desktop-debugger",
  "version": "0.1.0",
  "description": "可视化调试 vFlow 自动化工作流的桌面工具",
  "private": true,
  "main": "dist/main.js",
  "author": "ChaoMixian",
  "repository": {
    "type": "git",
    "url": "https://github.com/3481882553/vflow-desktop-debugger.git"
  },
  "keywords": [
    "vflow",
    "debugger",
    "electron",
    "react"
  ],
  "license": "MIT",
  "scripts": {
    "contracts:export-source": "node scripts/export_vflow_module_contracts.mjs",
    "contracts:export": "node scripts/export-module-contracts.mjs",
    "contracts:check": "node scripts/check-module-consistency.mjs",
    "contracts:check-display": "node scripts/check-display-consistency.mjs",
    "dev": "concurrently \"npm:dev-main\" \"npm:dev-renderer\"",
    "dev-main": "ts-node-esm src/main/main.ts",
    "dev-renderer": "vite --config vite.config.mts",
    "build": "npm run contracts:export-source && npm run contracts:export && npm run contracts:check && npm run contracts:check-display && npm run build-main && npm run build-renderer",
    "build-main": "tsc -p tsconfig.main.json",
    "build-renderer": "vite build --config vite.config.mts",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/run-e2e.mjs auto",
    "test:e2e:mock": "node scripts/run-e2e.mjs mock warn_skip none",
    "test:e2e:real": "node scripts/run-e2e.mjs real strict_fail none",
    "test:e2e:release": "node scripts/run-e2e.mjs real strict_fail release"
  },
  "build": {
    "appId": "com.vflow.debugger",
    "productName": "vFlow Debugger",
    "directories": {
      "output": "release-fixed"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
